import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        int target = 50; // 先固定答案方便測試
        Scanner sc = new Scanner(System.in);

        while (true) {
            System.out.print("請猜數字：");
            int guess = sc.nextInt();

            // 呼叫你的方法並接住結果
            int res = checkResult(guess, target);

            if (res == 1) {
                System.out.println("太大了!");
            } else if (res == -1) {
                System.out.println("太小了!");
            } else {
                System.out.println("賓果!");
                break;
            }
        }
    }

    // 在下面定義 checkResult 方法
    public static int checkResult(int guess, int target) {
        if (guess > target) {
            return 1;
        } else if (guess < target) {
            return -1;
        } else {
            return 0;
        }
    }
}