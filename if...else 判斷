import java.util.Scanner;

public class Main {
    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        while (true) {   // 無限迴圈
            System.out.print("請輸入年齡：");
            int age = scanner.nextInt();

            if (age >= 18) {
                System.out.println("已成年");
            } else {
                System.out.println("未成年");
            }
        }

    }
}